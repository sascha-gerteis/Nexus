PYTHON_RUNNER_SECRET=change-me-long-random-secret
NEXUS_RUNTIME_SECRET=copy-the-same-runtime-secret-used-by-supabase
PYTHON_JOB_IMAGE=nexus-python-job:latest
PYTHON_JOB_ROOT=/var/lib/nexus-python-runner/jobs
PYTHON_DEFAULT_TIMEOUT_SECONDS=120
PYTHON_MAX_TIMEOUT_SECONDS=300
PYTHON_KEEP_JOB_FILES=false
